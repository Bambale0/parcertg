# Notification bot from @BotFather. Required in every mode.
BOT_TOKEN=123456:replace_me
# One or more numeric Telegram user IDs allowed to control the bot.
ADMIN_IDS=123456789
# Chat/user where hot leads will be delivered. Defaults to first ADMIN_IDS value.
NOTIFY_CHAT_ID=123456789

# Cheap-by-default mode. Values: manual, tgstat, telethon (comma-separated).
# manual = forward Telemetr/TGStat alerts to this bot or use /lead.
SOURCE_PROVIDERS=manual

# Optional Telethon provider. Required only when SOURCE_PROVIDERS includes telethon.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Generate with: docker compose run --rm app python -m scripts.generate_session
TELEGRAM_SESSION=
# Default catalog contains 100 public Russian-language chats/channels.
CHAT_SOURCES_FILE=config/sources.txt
# Optional extra public usernames, t.me links or numeric IDs separated by commas.
CHAT_SOURCES=

# Optional TGStat Callback provider. Required only when SOURCE_PROVIDERS includes tgstat.
TGSTAT_TOKEN=
# Long random path secret, for example: python -c "import secrets; print(secrets.token_urlsafe(32))"
TGSTAT_WEBHOOK_SECRET=
# TGStat returns this code during the first callback URL setup attempt.
TGSTAT_VERIFY_CODE=
TGSTAT_QUERY_FILE=config/lead_query.tgstat
TGSTAT_SUBSCRIPTION_ID=
TGSTAT_QUEUE_SIZE=1000
# Public HTTPS address of this service, without a path.
PUBLIC_BASE_URL=https://leads.example.com
WEB_HOST=0.0.0.0
WEB_PORT=8080

DATABASE_URL=postgresql+asyncpg://parcertg:parcertg@db:5432/parcertg
MIN_LEAD_SCORE=65
DEDUP_WINDOW_HOURS=48
DEDUP_SIMILARITY=92
LOG_LEVEL=INFO
